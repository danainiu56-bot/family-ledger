.app { min-height: 100vh; }

/* 顶部月份切换 */
.topbar {
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 28rpx;
  padding: 24rpx 32rpx;
  background: var(--primary);
  color: #fff;
}
.month-nav {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.month-nav:active { background: rgba(255,255,255,.2); }
.month-label {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  min-width: 240rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 40rpx;
  letter-spacing: 1rpx;
}

/* 共享账本栏 */
.book-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 16rpx 32rpx;
  background: #eef2ff;
  border-bottom: 1rpx solid #c7d2fe;
  font-size: 26rpx;
}
.book-info { display: flex; align-items: center; gap: 16rpx; min-width: 0; flex: 1; }
.book-label { color: var(--text-muted); flex-shrink: 0; }
.book-id {
  font-weight: 700;
  color: var(--primary-dark);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.book-actions { display: flex; align-items: center; gap: 12rpx; flex-shrink: 0; }
.sync-indicator { display: flex; align-items: center; gap: 10rpx; max-width: 150rpx; }
.sync-status {
  font-size: 22rpx;
  color: var(--text-muted);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.book-btn {
  padding: 12rpx 20rpx;
  border-radius: 16rpx;
  background: #fff;
  color: var(--primary);
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.06);
}
.book-btn:active { background: #f1f5f9; }
.sync-dot {
  width: 16rpx; height: 16rpx;
  border-radius: 50%;
  background: var(--text-light);
  flex-shrink: 0;
}
.sync-dot.ok,
.sync-dot.live { background: var(--success); }
.sync-dot.syncing { background: var(--warning); }
.sync-dot.err { background: var(--danger); }

.sync-error {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  background: #fef2f2;
  border-bottom: 1rpx solid #fecaca;
  color: #b91c1c;
  font-size: 26rpx;
  line-height: 1.5;
}
.sync-error-msg { flex: 1; min-width: 0; }
.sync-retry-btn {
  flex-shrink: 0;
  padding: 10rpx 24rpx;
  border-radius: 16rpx;
  background: #fff;
  color: #b91c1c;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid #fecaca;
}

/* 内容区 */
.content {
  padding: 32rpx 32rpx calc(env(safe-area-inset-bottom) + 64rpx);
}

/* 预算总览卡片 */
.summary-card {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  border-radius: var(--radius);
  padding: 36rpx 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(99,102,241,.3);
  margin-bottom: 36rpx;
}
.summary-row { display: flex; }
.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  position: relative;
}
.summary-item + .summary-item::before {
  content: '';
  position: absolute;
  left: 0; top: 10%;
  height: 80%;
  width: 1rpx;
  background: rgba(255,255,255,.25);
}
.summary-label { font-size: 22rpx; opacity: .85; }
.summary-value { font-size: 34rpx; font-weight: 700; }
.summary-hint { font-size: 18rpx; opacity: .7; }

.progress-track {
  height: 14rpx;
  background: rgba(255,255,255,.25);
  border-radius: 8rpx;
  margin: 32rpx 0 24rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  width: 0;
  background: #fff;
  border-radius: 8rpx;
  transition: width .3s ease, background .3s ease;
}
.progress-fill.over { background: #fecaca; }

.summary-sub {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  opacity: .92;
}
.summary-sub .b { font-weight: 700; }

/* 分组 */
.group {
  background: var(--card);
  border-radius: var(--radius);
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.06);
  margin-bottom: 28rpx;
  overflow: hidden;
}
.group-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
}
.group-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-weight: 700;
  font-size: 32rpx;
}
.dot { width: 18rpx; height: 18rpx; border-radius: 50%; }
.dot-income { background: var(--income); }
.dot-saving { background: var(--saving); }
.dot-expense { background: var(--expense); }
.group-sum {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-muted);
  margin-left: 8rpx;
  white-space: nowrap;
}
.group-expenses .group-sum {
  white-space: normal;
  line-height: 1.4;
  max-width: 400rpx;
}
.add-btn {
  color: var(--primary);
  font-weight: 600;
  font-size: 28rpx;
  padding: 12rpx 20rpx;
  border-radius: var(--radius-sm);
}
.add-btn:active { background: var(--bg); }

/* 列表 */
.empty {
  text-align: center;
  color: var(--text-light);
  font-size: 26rpx;
  padding: 0 32rpx 36rpx;
}
.row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid var(--border);
}
.row:active { background: #f8fafc; }
.row-check {
  width: 44rpx; height: 44rpx;
  border-radius: 50%;
  border: 4rpx solid var(--border);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 26rpx;
}
.row-check.done { background: var(--success); border-color: var(--success); }
.row-check.partial {
  background: var(--warning);
  border-color: var(--warning);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1;
}
.row-main { flex: 1; min-width: 0; }
.row-name {
  font-size: 30rpx;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.row-name.done { color: var(--text-muted); text-decoration: line-through; }
.row-meta { font-size: 24rpx; color: var(--text-light); margin-top: 4rpx; }
.row-amount {
  text-align: right;
  font-weight: 700;
  font-size: 32rpx;
  flex-shrink: 0;
}
.row-amount.income { color: var(--income); }
.row-amount.saving { color: var(--saving); }
.row-amount .sub {
  display: block;
  font-size: 22rpx;
  font-weight: 500;
  color: var(--text-light);
}
.row-amount .pending { color: var(--warning); }
.row-amount .partial-main { color: var(--expense); }
.row-pay-btn {
  flex-shrink: 0;
  padding: 12rpx 20rpx;
  border-radius: 16rpx;
  background: #fff7ed;
  color: var(--expense);
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid #fed7aa;
}
.row-pay-btn:active { background: #ffedd5; }

.expense-summary {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 20rpx 24rpx;
  background: #fff7ed;
  border: 1rpx solid #fed7aa;
  border-radius: var(--radius-sm);
  font-size: 26rpx;
  color: var(--text-muted);
}
.expense-summary .b { color: var(--text); font-weight: 700; }
.field-hint {
  font-size: 24rpx;
  color: var(--text-light);
  line-height: 1.5;
}

/* 抽屉弹层 */
.drawer-mask {
  position: fixed;
  left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0,0,0,.4);
  z-index: 100;
}
.drawer {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  z-index: 101;
  background: var(--card);
  border-radius: 40rpx 40rpx 0 0;
  padding: 16rpx 40rpx calc(env(safe-area-inset-bottom) + 40rpx);
  box-shadow: 0 -16rpx 60rpx rgba(0,0,0,0.12);
}
.drawer-handle {
  width: 80rpx; height: 8rpx;
  background: var(--border);
  border-radius: 4rpx;
  margin: 12rpx auto 28rpx;
}
.drawer-title { font-size: 34rpx; font-weight: 700; margin-bottom: 32rpx; }
.drawer-desc {
  font-size: 26rpx;
  color: var(--text-muted);
  line-height: 1.6;
  margin: -16rpx 0 8rpx;
}
.drawer-form { display: flex; flex-direction: column; gap: 28rpx; }
.field { display: flex; flex-direction: column; gap: 12rpx; }
.field-label { font-size: 26rpx; color: var(--text-muted); font-weight: 500; }
.input {
  height: 96rpx;
  border: 3rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 0 28rpx;
  font-size: 32rpx;
  color: var(--text);
  background: #fff;
}
.picker-input {
  line-height: 96rpx;
  height: 96rpx;
}
.drawer-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 12rpx;
}
.drawer-actions-stack { flex-direction: column; }
.drawer-actions-stack .btn { width: 100%; }
.btn {
  flex: 1;
  height: 96rpx;
  border-radius: var(--radius-sm);
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  line-height: normal;
}
.btn::after { border: none; }
.btn-primary { background: var(--primary); color: #fff; }
.btn-primary:active { background: var(--primary-dark); }
.btn-cancel { background: var(--bg); color: var(--text-muted); }
.btn-ghost { background: #fef2f2; color: var(--danger); flex: 0 0 144rpx; }
